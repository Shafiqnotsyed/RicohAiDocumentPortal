@page
@model RicohAiDocumentPortal.Pages.Profile.PaymentModel
@{
    ViewData["Title"] = "Plans & Billing";
}

<section class="billing-page">
    <div class="billing-hero">
        <div class="billing-eyebrow">Plans & Billing</div>
        <h1>Unlock more value from your document AI workflow</h1>
        <p>
            A reliable AI layer helps users move beyond basic extraction into meaningful document improvement.
            It can highlight missing fields, identify risks, explain confusing sections, and guide users toward
            stronger, more accurate PDFs. A billing and payments layer makes it possible to scale that value
            with plans tailored to different usage needs.
        </p>
    </div>

    <div class="billing-intro-grid">
        <article class="billing-info-card">
            <h2>Why AI support matters</h2>
            <p>
                Businesses and individual users often need more than a simple PDF viewer. They need a system that can
                interpret document content, surface risks, and make suggestions that save time and reduce human error.
            </p>
            <ul>
                <li>Improve document quality before submission or sharing</li>
                <li>Catch missing information and formatting issues earlier</li>
                <li>Get faster summaries, insights, and guided explanations</li>
                <li>Support better decision-making with clearer PDF breakdowns</li>
            </ul>
        </article>

        <article class="billing-highlight-card">
            <div class="billing-highlight-badge">Recommended</div>
            <h2>Premium is the better choice</h2>
            <p>
                Premium unlocks a more capable version of the AI experience with deeper assistance, richer document
                explanations, and more detailed PDF breakdowns. It is ideal for users who need stronger support with
                invoices, reports, contracts, and other business documents.
            </p>
        </article>
    </div>

    <div class="billing-section">
        <div class="billing-section-head">
            <h2>Standard plan</h2>
            <p>For users who want dependable AI guidance for everyday document feedback and chat support.</p>
        </div>
        <div class="billing-plan-grid">
            <article class="pricing-card">
                <div class="pricing-term">Monthly</div>
                <div class="pricing-price">R149<span>/month</span></div>
                <ul>
                    <li>Core AI feedback and chat assistance</li>
                    <li>Document summaries and basic risk guidance</li>
                    <li>Suitable for lighter usage and short workflows</li>
                </ul>
                <button type="button" class="pricing-btn">Continue to Payment</button>
            </article>
            <article class="pricing-card">
                <div class="pricing-term">6 Month Plan</div>
                <div class="pricing-price">R799<span>/6 months</span></div>
                <ul>
                    <li>Better value for regular platform use</li>
                    <li>Consistent support for repeated PDF reviews</li>
                    <li>Ideal for students, small teams, and ongoing admin work</li>
                </ul>
                <button type="button" class="pricing-btn">Continue to Payment</button>
            </article>
            <article class="pricing-card">
                <div class="pricing-term">1 Year Plan</div>
                <div class="pricing-price">R1,499<span>/year</span></div>
                <ul>
                    <li>Best long-term value in the standard tier</li>
                    <li>Reliable support across the full year</li>
                    <li>Great for organisations with ongoing document workflows</li>
                </ul>
                <button type="button" class="pricing-btn">Continue to Payment</button>
            </article>
        </div>
    </div>

    <div class="billing-section premium-section">
        <div class="billing-section-head">
            <h2>Premium plan</h2>
            <p>For users who want a more advanced AI experience with better breakdowns, deeper context, and stronger PDF assistance.</p>
        </div>
        <div class="billing-plan-grid">
            <article class="pricing-card pricing-card-premium">
                <div class="pricing-term">Monthly</div>
                <div class="pricing-price">R249<span>/month</span></div>
                <ul>
                    <li>Enhanced AI responses with more detailed analysis</li>
                    <li>Richer document explanation and breakdown support</li>
                    <li>Better suited for complex or high-value PDFs</li>
                </ul>
                <button type="button" class="pricing-btn pricing-btn-premium">Continue to Payment</button>
            </article>
            <article class="pricing-card pricing-card-premium">
                <div class="pricing-term">6 Month Plan</div>
                <div class="pricing-price">R1,299<span>/6 months</span></div>
                <ul>
                    <li>Improved value for advanced users</li>
                    <li>More capable assistance for repeated document reviews</li>
                    <li>Strong option for growing teams and recurring analysis</li>
                </ul>
                <button type="button" class="pricing-btn pricing-btn-premium">Continue to Payment</button>
            </article>
            <article class="pricing-card pricing-card-premium">
                <div class="pricing-term">1 Year Plan</div>
                <div class="pricing-price">R2,399<span>/year</span></div>
                <ul>
                    <li>Best premium value for long-term use</li>
                    <li>Detailed AI help across a full year of document work</li>
                    <li>Excellent for businesses and demanding document workflows</li>
                </ul>
                <button type="button" class="pricing-btn pricing-btn-premium">Continue to Payment</button>
            </article>
        </div>
    </div>

    <div class="billing-note-card">
        <h3>Placeholder payment gateway</h3>
        <p>
            This page is currently a styled placeholder for a future payment gateway integration. A secure billing flow,
            payment provider connection, and subscription activation logic can be added later without changing the overall layout.
        </p>
    </div>
</section>
