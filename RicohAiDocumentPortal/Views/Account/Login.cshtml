@model RicohAiDocumentPortal.ViewModels.LoginViewModel

<div class="form-container">
    <div class="form-card">
        <h2>Login</h2>

        <form asp-action="Login" method="post">
            <div asp-validation-summary="All" class="validation-text"></div>

            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-input" />
                <span asp-validation-for="Email" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-input" type="password" />
                <span asp-validation-for="Password" class="validation-text"></span>
            </div>

            <button type="submit" class="btn-primary full-width">Login</button>
        </form>

        <p class="form-link">
            Don’t have an account?
            <a asp-controller="Account" asp-action="Register">Register here</a>
        </p>
    </div>
</div>