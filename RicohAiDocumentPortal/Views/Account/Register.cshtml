@model RicohAiDocumentPortal.ViewModels.RegisterViewModel

<div class="form-container">
    <div class="form-card">
        <h2>Sign Up</h2>

        <form asp-action="Register" method="post">
            <div asp-validation-summary="All" class="validation-text"></div>

            <div class="form-group">
                <label asp-for="FullName"></label>
                <input asp-for="FullName" class="form-input" />
                <span asp-validation-for="FullName" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-input" />
                <span asp-validation-for="Email" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-input" type="password" />
                <span asp-validation-for="Password" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword"></label>
                <input asp-for="ConfirmPassword" class="form-input" type="password" />
                <span asp-validation-for="ConfirmPassword" class="validation-text"></span>
            </div>

            <button type="submit" class="btn-primary full-width">Create Account</button>
        </form>
    </div>
</div>