<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ricoh AI Document Portal</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar">
            <div class="nav-brand">
                <a asp-controller="Home" asp-action="Index" class="brand-link">Ricoh AI Document Portal</a>
            </div>

            <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation">
                ☰
            </button>

            <ul class="nav-links" id="navMenu">
                <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li><a asp-controller="Account" asp-action="Login">Login</a></li>
                <li><a asp-controller="Account" asp-action="Register">Sign Up</a></li>
                <li><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li><a asp-controller="Document" asp-action="Feedback">Feedback</a></li>
                <li><a asp-controller="Document" asp-action="Chat">Chat</a></li>
                <li><a asp-controller="Profile" asp-action="Index">Profile</a></li>
            </ul>
        </nav>
    </header>

    <main class="page-shell">
        <section class="main-content">
            @RenderBody()
        </section>
    </main>

    <footer class="footer">
        <p>&copy; 2026 Ricoh AI Document Portal. All rights reserved.</p>
    </footer>

    <script>
            document.addEventListener("DOMContentLoaded", function () {
                const navToggle = document.getElementById("navToggle");
                const navMenu = document.getElementById("navMenu");

                if (navToggle && navMenu) {
                    navToggle.addEventListener("click", function () {
                        navMenu.classList.toggle("show");
                    });
                }
            });
    </script>
</body>
</html>