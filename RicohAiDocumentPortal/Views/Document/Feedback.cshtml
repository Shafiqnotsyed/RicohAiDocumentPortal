@model RicohAiDocumentPortal.Models.AnalyzeDocumentRequest

<h1>Analyze Document Text</h1>

@if (TempData["ErrorMessage"] != null)
{
    <p style="color:red;">@TempData["ErrorMessage"]</p>
}

<form asp-action="Feedback" method="post">
    <div>
        <label asp-for="FileName"></label>
        <input asp-for="FileName" />
    </div>

    <div>
        <label asp-for="DocumentText"></label>
        <textarea asp-for="DocumentText" rows="12" cols="80"></textarea>
    </div>

    <button type="submit">Analyze with AI</button>
</form>