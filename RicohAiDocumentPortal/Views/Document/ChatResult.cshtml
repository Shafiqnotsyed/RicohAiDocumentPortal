@model RicohAiDocumentPortal.Models.ChatDocumentResponse

<section class="chat-container">
    <h1 class="page-title">AI Response</h1>
    <p class="chat-subtitle">Here’s what the AI found based on your document.</p>

    <div class="chat-box">
        <div id="typingAnswer" class="typing-answer"></div>
    </div>

    <div class="chat-actions">
        <a asp-controller="Document" asp-action="Chat" class="btn-primary">
            Ask Another Question
        </a>
    </div>
</section>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const typingTarget = document.getElementById("typingAnswer");
        if (!typingTarget) return;

        const finalHtml = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Answer));
        const tempContainer = document.createElement("div");
        tempContainer.innerHTML = finalHtml;

        const nodes = Array.from(tempContainer.childNodes);
        let nodeIndex = 0;
        const speed = 16;

        function typeTextIntoElement(element, text, callback) {
            let i = 0;

            function step() {
                if (i < text.length) {
                    element.textContent += text.charAt(i);
                    i++;
                    setTimeout(step, speed);
                } else {
                    callback();
                }
            }

            step();
        }

        function processNextNode() {
            if (nodeIndex >= nodes.length) {
                return;
            }

            const node = nodes[nodeIndex];
            nodeIndex++;

            if (node.nodeType === Node.TEXT_NODE) {
                if (node.textContent.trim() === "") {
                    processNextNode();
                    return;
                }

                const p = document.createElement("p");
                typingTarget.appendChild(p);

                typeTextIntoElement(p, node.textContent.trim(), processNextNode);
                return;
            }

            if (node.nodeType === Node.ELEMENT_NODE) {
                const tag = node.tagName.toLowerCase();

                if (tag === "h1" || tag === "h2" || tag === "h3" || tag === "h4") {
                    const heading = document.createElement(tag);
                    typingTarget.appendChild(heading);
                    typeTextIntoElement(heading, node.textContent.trim(), processNextNode);
                    return;
                }

                if (tag === "p") {
                    const p = document.createElement("p");
                    typingTarget.appendChild(p);
                    typeTextIntoElement(p, node.textContent.trim(), processNextNode);
                    return;
                }

                if (tag === "ul" || tag === "ol") {
                    const list = document.createElement(tag);
                    typingTarget.appendChild(list);

                    const items = Array.from(node.children);
                    let itemIndex = 0;

                    function processListItem() {
                        if (itemIndex >= items.length) {
                            processNextNode();
                            return;
                        }

                        const sourceItem = items[itemIndex];
                        itemIndex++;

                        const li = document.createElement("li");
                        list.appendChild(li);

                        typeTextIntoElement(li, sourceItem.textContent.trim(), processListItem);
                    }

                    processListItem();
                    return;
                }

                if (tag === "br") {
                    typingTarget.appendChild(document.createElement("br"));
                    processNextNode();
                    return;
                }

                const fallback = document.createElement("p");
                typingTarget.appendChild(fallback);
                typeTextIntoElement(fallback, node.textContent.trim(), processNextNode);
                return;
            }

            processNextNode();
        }

        processNextNode();
    });
</script>