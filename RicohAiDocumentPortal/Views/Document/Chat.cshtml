@model RicohAiDocumentPortal.Models.ChatDocumentRequest

<h1>Chat with Document</h1>

@if (TempData["ErrorMessage"] != null)
{
    <p style="color:red;">@TempData["ErrorMessage"]</p>
}

<form asp-action="Chat" method="post">
    <div>
        <label asp-for="DocumentText"></label>
        <textarea asp-for="DocumentText" rows="12" cols="80"></textarea>
    </div>

    <div>
        <label asp-for="Question"></label>
        <input asp-for="Question" />
    </div>

    <button type="submit">Ask AI</button>
</form>